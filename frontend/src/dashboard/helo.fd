<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PowerGuide Dashboard</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100;300;400;600;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
        }
        /* Custom Glowing Hover States */
        .card-hover {
            transition: all 0.3s ease-in-out;
        }
        .card-hover:hover {
            transform: translateY(-4px);
        }
        .glow-voltage:hover {
            box-shadow: 0 10px 25px -5px rgba(0, 207, 255, 0.2);
            border-color: rgba(0, 207, 255, 0.4);
        }
        .glow-uptime:hover {
            box-shadow: 0 10px 25px -5px rgba(250, 176, 5, 0.2);
            border-color: rgba(250, 176, 5, 0.4);
        }
        .glow-reports:hover {
            box-shadow: 0 10px 25px -5px rgba(203, 52, 53, 0.2);
            border-color: rgba(203, 52, 53, 0.4);
        }
        .glow-readiness:hover {
            box-shadow: 0 10px 25px -5px rgba(95, 203, 95, 0.2);
            border-color: rgba(95, 203, 95, 0.4);
        }
    </style>
</head>

<body class="bg-[#03041A] text-white">

    <!-- Mobile Menu Toggle -->
    <button id="menuToggle" class="fixed top-4 left-4 z-50 lg:hidden bg-[#31324C] p-2 rounded-lg focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>

    <!-- Overlay for mobile -->
    <div id="overlay" class="fixed inset-0 bg-black/50 z-30 hidden lg:hidden"></div>
    <div class="flex h-screen overflow-hidden">

        <!-- SIDEBAR NAV -->
        <nav id="sidebar" class="flex flex-col fixed lg:sticky top-0 h-screen w-[280px] lg:w-[340px]
                text-[#B5B5B5] text-center pt-8 px-5
                border-r-2 border-white/10 bg-[#03041A] z-40
                -translate-x-full lg:translate-x-0 transition-transform duration-300">

            <!-- Logo -->
            <div class="flex items-center gap-2 ml-4 mb-6">
                <!-- Inline alternative SVG Logo for PowerGuide -->
                <svg class="w-10 h-10 text-[#FFBB02]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11.5 22C5.148 22 0 16.852 0 10.5S5.148-1 11.5-1 23 4.148 23 10.5 17.852 22 11.5 22zm0-21C6.262 1 2 5.262 2 10.5S6.262 20 11.5 20 21 15.738 21 10.5 16.738 1 11.5 1zm.25 4.5v5l3.25 3.25-.75.75-3.5-3.5v-5.5h1z"/>
                    <path d="M12 2l-5.5 9h4.5v7l5.5-9h-4.5z"/>
                </svg>
                <div class="flex flex-col justify-center items-start">
                    <span class="text-white font-bold text-lg md:text-xl leading-tight">
                        POWER<span class="text-[#FFBB02]">GUIDE</span>
                    </span>
                    <span class="text-white font-medium text-sm md:text-xs tracking-widest opacity-70 leading-none">
                        SECURITY AND RELIABILITY
                    </span>
                </div>
            </div>

            <!-- Nav Links -->
            <div class="flex flex-col gap-2">
                <span class="text-xs font-bold tracking-widest text-white text-left px-4 pt-4 mb-2">MAIN MENU</span>
                
                <a href="#" class="group flex flex-row items-center gap-3 px-4 h-11 rounded-lg bg-[#FEBB02] text-black hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 ease-in-out">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
                    <span class="text-sm font-semibold">Dashboard</span>
                </a>

                <a href="#" class="group flex flex-row items-center gap-3 px-4 h-11 rounded-lg hover:bg-[#FEBB02] hover:text-black duration-200 hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 ease-in-out">
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                    <span class="text-sm font-semibold">Outage Map</span>
                </a>

                <a href="#" class="group flex flex-row items-center gap-3 px-4 h-11 rounded-lg hover:bg-[#FEBB02] hover:text-black duration-200 hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 ease-in-out">
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span class="text-sm font-semibold">Find Hubs</span>
                </a>

                <span class="text-xs font-bold tracking-widest text-white text-left px-4 pt-4 mb-2 mt-2">COMMUNITY</span>

                <a href="#" class="group flex flex-row items-center gap-3 px-4 h-11 rounded-lg hover:bg-[#FEBB02] hover:text-black duration-200 hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 ease-in-out">
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="text-sm font-semibold">Reports</span>
                </a>

                <a href="#" class="group flex flex-row items-center gap-3 px-4 h-11 rounded-lg hover:bg-[#FEBB02] hover:text-black duration-200 transition-all duration-200 ease-in-out">
                    <svg class="w-5 h-5 text-gray-400 group-hover:text-black" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span class="text-sm font-semibold">Settings</span>
                </a>
            </div>

            <!-- Pro Tip -->
            <div class="flex flex-col text-left mt-auto mb-8 mx-2 p-6 rounded-lg bg-[#31324C]/50">
                <span class="text-[#FEBB02] text-base font-bold mb-1">PRO TIP</span>
                <span class="text-white/50 text-sm font-normal">Lower screen brightness to 40% to save 15min of runtime.</span>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="flex-1 overflow-y-auto">

            <!-- HEADER -->
            <header class="mx-2 lg:mx-4 mt-14 lg:mt-4 mb-4 p-2 lg:p-3 flex flex-col sm:flex-row justify-between gap-4">
                <div>
                    <h1 class="text-3xl lg:text-4xl font-bold">Welcome Back, Alex!</h1>
                    <span class="text-sm lg:text-base text-[#B5B5B5] flex items-center gap-2 mt-1">
                        Grid status:
                        <span class="flex items-center gap-1.5 text-[#00BA00]">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            Stable in Dagupan City
                        </span>
                    </span>
                </div>

                <div class="flex items-center gap-6">
                    <div class="relative">
                        <!-- Bell Icon Toggle Button -->
                        <button id="notifBtn" class="relative group p-2 rounded-full hover:bg-white/5 transition-colors focus:outline-none">
                            <svg class="w-7 h-7 text-[#FFBB02]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                            </svg>
                            <span class="absolute top-1.5 right-1.5 w-2.5 h-2.5 bg-red-500 rounded-full"></span>
                        </button>

                        <!-- Notification Panel -->
                        <div id="notifPanel" class="absolute right-0 mt-4 w-[350px] bg-[#222338] border border-white/10 rounded-2xl shadow-2xl z-50
                                opacity-0 pointer-events-none -translate-y-2 scale-95
                                transition-all duration-200 ease-out">
                            <section class="flex flex-col p-4">
                                <!-- Header -->
                                <div class="flex flex-row items-center gap-2 mb-4 pb-2 border-b border-white/5">
                                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                                    <h1 class="text-sm font-bold text-white">Notifications</h1>
                                </div>

                                <!-- Scrollable Content -->
                                <div class="flex flex-col gap-3 max-h-80 overflow-y-auto pr-1">
                                    <!-- Report 1 -->
                                    <div class="flex flex-row items-center gap-3 bg-[#0D0E2A] rounded-xl p-3 relative">
                                        <span class="absolute top-2 right-3 text-gray-500 text-[10px]">10m ago</span>
                                        <div class="p-2 rounded-lg bg-red-500/20 text-red-400">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-white font-bold text-xs">Voltage Spike Detected</span>
                                            <span class="text-[#B5B5B5] text-[11px]">Substation 4B reported fluctuation</span>
                                        </div>
                                    </div>

                                    <!-- Report 2 -->
                                    <div class="flex flex-row items-center gap-3 bg-[#0D0E2A] rounded-xl p-3 relative">
                                        <span class="absolute top-2 right-3 text-gray-500 text-[10px]">1h ago</span>
                                        <div class="p-2 rounded-lg bg-blue-500/20 text-blue-400">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path></svg>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-white font-bold text-xs">Scheduled Maintenance</span>
                                            <span class="text-[#B5B5B5] text-[11px]">System update finalized at 14:00</span>
                                        </div>
                                    </div>
                                </div>
                            </section>
                        </div>
                    </div>

                    <!-- Profile initials -->
                    <button id="profileBtn" class="focus:outline-none">
                        <div class="h-12 w-12 rounded-full border-2 border-[#FFBB02]
                            flex items-center justify-center cursor-pointer
                            hover:bg-[#FFBB02] hover:text-black
                            text-white font-bold text-sm
                            transition-all duration-200 transform hover:scale-105">
                            AD
                        </div>
                    </button>
                </div>
            </header>

            <!-- STAT CARDS -->
            <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 lg:gap-8 px-4 lg:px-8">
                <!-- Voltage -->
                <div class="card-hover glow-voltage bg-[#31324C]/50 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 min-h-[170px] w-full cursor-pointer">
                    <div class="flex justify-between items-start">
                        <div class="bg-[#1A1B3A] p-2 rounded-xl text-[#00CFFF]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <span class="text-[#00CFFF] text-sm font-semibold tracking-widest mt-2">VOLTAGE</span>
                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="text-white text-4xl font-bold">
                            231 <span class="text-xl text-[#B5B5B5] font-normal">v</span>
                        </span>
                        <span class="text-[#B5B5B5] text-sm">Nominal operating range</span>
                    </div>
                </div>

                <!-- Avg Uptime -->
                <div class="card-hover glow-uptime bg-[#31324C]/50 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 min-h-[170px] w-full cursor-pointer">
                    <div class="flex justify-between items-start">
                        <div class="bg-[#1A1B3A] p-2 rounded-xl text-[#FAB005]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="text-[#FAB005] text-sm font-semibold tracking-widest mt-2">AVG. UPTIME</span>
                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="text-white text-4xl font-bold">
                            99.94 <span class="text-xl text-[#B5B5B5] font-normal">%</span>
                        </span>
                        <span class="text-[#29AC47] text-sm">+0.02% from last week</span>
                    </div>
                </div>

                <!-- Local Reports -->
                <div class="card-hover glow-reports bg-[#31324C]/50 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 min-h-[170px] w-full cursor-pointer">
                    <div class="flex justify-between items-start">
                        <div class="bg-[#1A1B3A] p-2 rounded-xl text-[#CB3435]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        </div>
                        <span class="text-[#CB3435] text-sm font-semibold tracking-widest mt-2">LOCAL REPORTS</span>
                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="text-white text-4xl font-bold">
                            0 <span class="text-xl text-[#B5B5B5] font-normal">Active</span>
                        </span>
                        <span class="text-[#B5B5B5] text-sm">No issues in your immediate vicinity</span>
                    </div>
                </div>

                <!-- Readiness -->
                <div class="card-hover glow-readiness bg-[#31324C]/50 border border-white/5 rounded-2xl p-5 flex flex-col gap-4 min-h-[170px] w-full cursor-pointer">
                    <div class="flex justify-between items-start">
                        <div class="bg-[#1A1B3A] p-2 rounded-xl text-[#5FCB5F]">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <span class="text-[#5FCB5F] text-sm font-semibold tracking-widest mt-2">READINESS</span>
                    </div>
                    <div class="flex flex-col gap-1">
                        <span class="text-white text-4xl font-bold">Optimal</span>
                        <span class="text-[#B5B5B5] text-sm">Backup systems verified</span>
                    </div>
                </div>
            </section>

            <!-- CENTER SECTION -->
            <section class="flex flex-col xl:flex-row gap-4 lg:gap-8 px-4 lg:px-8 mt-8 pb-4">
                <!-- LEFT: Map -->
                <div class="flex flex-col gap-6 max-w-[900px] w-full">
                    <div class="rounded-2xl overflow-hidden border border-white/5">
                        <div class="bg-[#31324C]/50 flex flex-row justify-between items-center p-6">
                            <div class="flex flex-row items-center gap-3">
                                <svg class="w-6 h-6 text-[#FFBB02]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                <span class="font-bold text-sm lg:text-base">Local Activity Map</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-[#B5B5B5] px-3 py-1.5 bg-[#0E0F26] text-xs rounded-lg font-bold">PH-NCR</span>
                                <span class="text-[#29AC47] px-3 py-1.5 bg-[#0E0F26] text-xs rounded-lg font-bold flex items-center gap-1.5">
                                    <span class="w-2 h-2 rounded-full bg-[#29AC47] animate-pulse"></span>LIVE
                                </span>
                            </div>
                        </div>
                        <!-- Clean Abstract CSS grid background layout replacing static map.png missing asset -->
                        <div class="w-full h-80 lg:h-[420px] bg-[#0A0B1A] relative overflow-hidden flex items-center justify-center">
                            <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-[size:40px_40px]"></div>
                            <div class="absolute w-72 h-72 rounded-full bg-blue-500/10 blur-3xl"></div>
                            <div class="absolute w-48 h-48 rounded-full bg-yellow-500/5 blur-2xl top-10 right-20"></div>
                            <!-- Mock Node Elements representing clean data map infrastructure visually -->
                            <div class="z-10 flex flex-col items-center gap-2 bg-[#1A1B33]/80 p-4 border border-white/10 rounded-xl backdrop-blur">
                                <span class="text-xs font-semibold text-gray-400">Regional Power Infrastructure Map</span>
                                <span class="text-[11px] text-gray-500">Node Grid Synchronized Seamlessly</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Device Battery Circle Widget -->
                <div class="flex flex-col gap-6 xl:w-80">
                    <div class="rounded-2xl bg-[#31324C]/50 border border-white/5 flex flex-col items-center justify-between p-6 min-h-[503px]">
                        <span class="text-white text-sm font-bold mt-4">This Device</span>

                        <!-- Battery Ring dynamically fueled by Javascript implementation -->
                        <div class="relative flex items-center justify-center my-6">
                            <svg class="w-40 h-40 -rotate-90" viewBox="0 0 120 120">
                                <circle cx="60" cy="60" r="50" fill="none" stroke="#1A1B3A" stroke-width="10" />
                                <circle id="battery-ring" cx="60" cy="60" r="50" fill="none" stroke="#FFBB02"
                                    stroke-width="10" stroke-linecap="round" stroke-dasharray="314"
                                    stroke-dashoffset="314" class="transition-all duration-500" />
                            </svg>
                            <div class="absolute flex flex-col items-center">
                                <div id="level" class="text-white text-3xl font-bold">--%</div>
                                <span class="text-[#B5B5B5] text-[10px] tracking-widest mt-0.5">BATTERY</span>
                            </div>
                        </div>

                        <!-- Device Live State Metric Panel -->
                        <div class="flex flex-row w-full gap-3 text-xs mb-4">
                            <div class="flex flex-col items-center bg-[#1A1B3A] rounded-xl p-3 flex-1 border border-white/5">
                                <span class="text-[#B5B5B5] text-[10px] tracking-widest">STATE</span>
                                <div id="status" class="text-[#FFBB02] font-bold text-sm mt-1">Checking...</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- RECENT COMMUNITY REPORTS LIST SECTION -->
            <section class="flex flex-col xl:flex-row gap-6 px-4 lg:px-8 pb-10">
                <div class="bg-[#31324C]/50 border border-white/5 rounded-2xl p-6 flex flex-col gap-4 w-full">
                    <div class="flex flex-row items-center gap-2">
                        <svg class="w-5 h-5 text-[#FFBB02]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                        <h1 class="text-lg font-bold">Recent Incident Logs</h1>
                    </div>

                    <!-- Log 1 -->
                    <div class="flex flex-row items-center gap-4 bg-[#0D0E2A] rounded-xl px-5 py-4 relative min-h-24">
                        <span class="absolute top-4 right-5 text-gray-500 text-xs">2 hours ago</span>
                        <div class="p-2.5 rounded-xl bg-red-500/20 text-red-400">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-bold text-sm lg:text-base">Transient Voltage Drop</span>
                            <span class="text-[#B5B5B5] text-xs lg:text-sm">Calasiao Sector line recorded minimal drop, quickly corrected.</span>
                        </div>
                    </div>

                    <!-- Log 2 -->
                    <div class="flex flex-row items-center gap-4 bg-[#0D0E2A] rounded-xl px-5 py-4 relative min-h-24">
                        <span class="absolute top-4 right-5 text-gray-500 text-xs">Yesterday</span>
                        <div class="p-2.5 rounded-xl bg-blue-500/20 text-blue-400">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-bold text-sm lg:text-base">Substation Breaker Optimization</span>
                            <span class="text-[#B5B5B5] text-xs lg:text-sm">Routine architectural diagnostics resolved grid constraints flawlessly.</span>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Low Battery Warning Toast Panel -->
    <div id="battery-warning" class="fixed inset-0 bg-black/60 flex justify-center items-center z-50 p-4 opacity-0 invisible pointer-events-none transition-all duration-300">
        <div id="batteryBox" class="bg-[#1A1B33] border-2 border-red-600 rounded-3xl p-8 max-w-sm w-full flex flex-col items-center gap-4 text-center scale-95 translate-y-4 opacity-0 transition-all duration-300 ease-out">
            <span class="text-red-500 text-5xl">⚠️</span>
            <h2 class="text-white text-xl font-bold">Battery Low!</h2>
            <p class="text-[#B5B5B5] text-sm">Please connect your charger immediately to safely maintain grid surveillance operational flow.</p>
            <button onclick="closeBatteryWarning()" class="mt-2 px-6 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded-full transition-all duration-200">
                Got it
            </button>
        </div>
    </div>

    <!-- PROFILE SETTINGS MODAL DIALOG -->
    <div id="profile" class="fixed inset-0 bg-black/60 flex justify-center items-center z-50 p-3 sm:p-6 opacity-0 invisible pointer-events-none transition-all duration-300 ease-out">
        <div id="profileBox" class="relative w-full max-w-[700px] shadow-[0_0_30px_rgba(255,187,2,0.3)] rounded-[20px] overflow-hidden transform scale-95 translate-y-4 opacity-0 transition-all duration-300 ease-out">
            
            <!-- Close Button -->
            <button onclick="closeProfile()" class="absolute top-4 right-4 text-white text-3xl font-light hover:text-[#FFBB02] z-10 leading-none px-2 focus:outline-none">&times;</button>

            <!-- Content Area -->
            <div class="flex flex-col w-full max-h-[90vh] overflow-y-auto bg-[#1A1B33] text-white rounded-[20px] px-6 pb-6 pt-6 md:px-10 md:pb-10 md:pt-7">
                <span class="flex flex-col text-2xl md:text-3xl font-bold mb-4">
                    Profile Settings
                    <span class="text-sm font-semibold text-[#B5B5B5] mt-1">Manage your corporate credentials and security tokens.</span>
                </span>

                <div class="flex flex-col">
                    <!-- Basic Information Header -->
                    <div class="flex items-center gap-2 py-4 text-[#FFBB02]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        <span class="text-white text-[13px] font-bold tracking-wide">BASIC INFORMATION</span>
                    </div>

                    <!-- Basic Info Fields -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-white text-[13px] font-semibold">Full Name</label>
                            <input class="h-10 border border-white/20 rounded-lg text-white font-medium px-3 bg-white/5 focus:border-[#FFBB02] focus:outline-none text-sm w-full" type="text" value="Alex Mercer">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-white text-[13px] font-semibold">Contact Number</label>
                            <input class="h-10 border border-white/20 rounded-lg text-white font-medium px-3 bg-white/5 focus:border-[#FFBB02] focus:outline-none text-sm w-full" type="text" value="+63 912 123 4567">
                        </div>
                    </div>

                    <div class="py-4 border-b border-white/10 mb-4">
                        <button onclick="closeProfile()" class="h-[42px] w-full rounded-lg bg-[#FFBB02] text-sm font-bold text-black cursor-pointer transition-all duration-200 ease-in-out hover:bg-[#D99A00] active:scale-95 mb-2">
                            Update Basic Profile
                        </button>
                    </div>

                    <!-- Security Header -->
                    <div class="flex items-center gap-2 py-2 text-[#FFBB02]">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                        <span class="text-white text-[13px] font-bold tracking-wide">SECURITY AND PASSWORD</span>
                    </div>

                    <!-- Password Fields -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-white text-[13px] font-semibold">New Password</label>
                            <input class="h-10 border border-white/20 rounded-lg text-white font-medium px-3 bg-white/5 focus:border-[#FFBB02] focus:outline-none text-sm w-full" type="password" placeholder="••••••••">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-white text-[13px] font-semibold">Confirm Password</label>
                            <input class="h-10 border border-white/20 rounded-lg text-white font-medium px-3 bg-white/5 focus:border-[#FFBB02] focus:outline-none text-sm w-full" type="password" placeholder="••••••••">
                        </div>
                    </div>

                    <div class="pt-6">
                        <button onclick="closeProfile()" class="w-full h-[42px] rounded-lg bg-[#FFBB02] text-sm font-bold text-black cursor-pointer transition-all duration-200 ease-in-out hover:bg-[#D99A00] active:scale-95">
                            Change Password
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DOM AND DATA CONTROLLER SCRIPT CODE -->
    <script>
        // --- 1. Mobile Sidebar Navigation System ---
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        function toggleMobileMenu() {
            sidebar.classList.toggle('-translate-x-full');
            overlay.classList.toggle('hidden');
        }

        menuToggle.addEventListener('click', toggleMobileMenu);
        overlay.addEventListener('click', toggleMobileMenu);

        // --- 2. Interactive Notification UI Component Control ---
        const notifBtn = document.getElementById('notifBtn');
        const notifPanel = document.getElementById('notifPanel');

        notifBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !notifPanel.classList.contains('opacity-0');
            if (isOpen) {
                closeNotificationPanel();
            } else {
                notifPanel.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-2', 'scale-95');
            }
        });

        function closeNotificationPanel() {
            notifPanel.classList.add('opacity-0', 'pointer-events-none', '-translate-y-2', 'scale-95');
        }

        // --- 3. Profile Editor Modal Layer View Controllers ---
        const profileModal = document.getElementById('profile');
        const profileBox = document.getElementById('profileBox');
        const profileBtn = document.getElementById('profileBtn');

        function openProfile() {
            profileModal.classList.remove('opacity-0', 'invisible');
            setTimeout(() => {
                profileBox.classList.remove('scale-95', 'translate-y-4', 'opacity-0');
            }, 50);
        }

        function closeProfile() {
            profileBox.classList.add('scale-95', 'translate-y-4', 'opacity-0');
            setTimeout(() => {
                profileModal.classList.add('opacity-0', 'invisible');
            }, 300);
        }

        profileBtn.addEventListener('click', openProfile);
        profileModal.addEventListener('click', (e) => {
            if (e.target === profileModal) closeProfile();
        });

        // --- 4. Global UI Context Dismissal Helper ---
        window.addEventListener('click', () => {
            closeNotificationPanel();
        });

        // --- 5. Hardwired Machine Systems Battery API Aggregator ---
        const batteryRing = document.getElementById('battery-ring');
        const batteryLevelTxt = document.getElementById('level');
        const batteryStatusTxt = document.getElementById('status');
        const batteryWarningToast = document.getElementById('battery-warning');
        const batteryBox = document.getElementById('batteryBox');

        function updateCircularSVGProgress(percentage) {
            const radius = 50;
            const circumference = 2 * Math.PI * radius; // Approx 314
            const offset = circumference - (percentage / 100) * circumference;
            batteryRing.style.strokeDashoffset = offset;
        }

        function dispatchBatteryUIChanges(battery) {
            const levelRounded = Math.round(battery.level * 100);
            batteryLevelTxt.innerText = `${levelRounded}%`;

            // State definitions
            if (battery.charging) {
                batteryStatusTxt.innerText = "Charging";
                batteryStatusTxt.style.color = "#5FCB5F";
                batteryRing.style.stroke = "#5FCB5F";
            } else {
                batteryStatusTxt.innerText = "Discharging";
                batteryStatusTxt.style.color = "#FFBB02";
                
                if (levelRounded <= 20) {
                    batteryStatusTxt.innerText = "Low Battery";
                    batteryStatusTxt.style.color = "#EF4444";
                    batteryRing.style.stroke = "#EF4444";
                    triggerBatteryWarningToast();
                } else {
                    batteryRing.style.stroke = "#FFBB02";
                }
            }
            updateCircularSVGProgress(levelRounded);
        }

        function triggerBatteryWarningToast() {
            batteryWarningToast.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
            setTimeout(() => {
                batteryBox.classList.remove('scale-95', 'translate-y-4', 'opacity-0');
            }, 50);
        }

        function closeBatteryWarning() {
            batteryBox.classList.add('scale-95', 'translate-y-4', 'opacity-0');
            setTimeout(() => {
                batteryWarningToast.classList.add('opacity-0', 'invisible', 'pointer-events-none');
            }, 300);
        }

        // Initialize Native Battery Listeners if browser framework permits usage
        if (navigator.getBattery) {
            navigator.getBattery().then((battery) => {
                dispatchBatteryUIChanges(battery);

                battery.addEventListener('levelchange', () => dispatchBatteryUIChanges(battery));
                battery.addEventListener('chargingchange', () => dispatchBatteryUIChanges(battery));
            });
        } else {
            // Fallback parameters if viewing on non-supported desktop platform architectures
            batteryLevelTxt.innerText = "84%";
            batteryStatusTxt.innerText = "Discharging";
            updateCircularSVGProgress(84);
        }
    </script>
</body>

</html>